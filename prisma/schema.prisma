generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIO ─────────────────────────────────────────────────
// Sin cambios — igual al original
model Usuario {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  nombre             String
  empresa            String
  pais               String              @default("Argentina")
  matricula          String?             @default("")
  dni                String?             @default("")
  plan               String              @default("demo")
  demoStartAt        DateTime?
  planElegido        Boolean             @default(false)
  activo             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  resetToken         String?             @unique
  resetTokenExpira   DateTime?
  consultasIaUsadas  Int                 @default(0)
  consultasIaResetEn DateTime?
  equipoId           String?
  equipo             Equipo?             @relation("EquipoMiembros", fields: [equipoId], references: [id])
  equiposPropios     Equipo[]            @relation("EquipoOwner")
  calculos           Calculo[]
  proyectos          Proyecto[]
  activosTelemetria  ActivoTelemetria[]
  lecturasTelemetria LecturaTelemetria[]
}

// ─── EQUIPO ──────────────────────────────────────────────────
// Plan Team: un dueño (owner) crea un equipo e invita miembros.
// Un usuario pertenece a lo sumo a un equipo (equipoId en Usuario).
model Equipo {
  id           String             @id @default(cuid())
  nombre       String
  ownerId      String
  owner        Usuario            @relation("EquipoOwner", fields: [ownerId], references: [id])
  miembros     Usuario[]          @relation("EquipoMiembros")
  invitaciones InvitacionEquipo[]
  createdAt    DateTime           @default(now())
  proyectos    Proyecto[]
}

// ─── INVITACION EQUIPO ────────────────────────────────────────
// Invitación pendiente de aceptación para unirse a un Equipo.
model InvitacionEquipo {
  id        String   @id @default(cuid())
  email     String
  equipoId  String
  equipo    Equipo   @relation(fields: [equipoId], references: [id])
  token     String   @unique
  estado    String   @default("pendiente")
  createdAt DateTime @default(now())
}

// ─── PROYECTO ─────────────────────────────────────────────────
// Agrupa cálculos del mismo activo físico en el tiempo.
// Base del Asset Integrity Management de INGENIUM PRO.
model Proyecto {
  id                String             @id @default(cuid())
  nombre            String
  industria         String             @default("Petróleo / Gas")
  fluido            String?
  presion_bar       Float?
  temp_c            Float?
  nps               String?
  material          String?
  norma             String             @default("ASME B31.8")
  H2S_ppm           Float?             @default(0)
  zona_elec         String?
  pais              String             @default("Argentina")
  activo            Boolean            @default(true)
  usuarioId         String
  usuario           Usuario            @relation(fields: [usuarioId], references: [id])
  equipoId          String?
  equipo            Equipo?            @relation(fields: [equipoId], references: [id])
  calculos          Calculo[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activosTelemetria ActivoTelemetria[]
}

// ─── CALCULO ──────────────────────────────────────────────────
// Cada cálculo individual con historial y QR verificable.
// Todos los campos nuevos son opcionales — no rompe datos existentes.
model Calculo {
  id           String    @id @default(cuid())
  tipo         String
  moduloId     String?
  submodulo    String?
  activoNombre String?
  parametros   Json
  resultado    Json
  normativa    String?
  hash         String?   @unique
  firma        String?
  alerta       Boolean   @default(false)
  alertaMsg    String?
  usuario      String    @default("anonimo")
  usuarioId    String?
  proyectoId   String?
  user         Usuario?  @relation(fields: [usuarioId], references: [id])
  proyecto     Proyecto? @relation(fields: [proyectoId], references: [id])
  createdAt    DateTime  @default(now())
}

// ─── ACTIVO TELEMETRIA ──────────────────────────────────────────
// Activo físico monitoreado, cuelga de un Proyecto. Geometría como JSON en texto.
model ActivoTelemetria {
  id            String              @id @default(cuid())
  nombre        String
  tipoActivo    String
  geometriaJson String
  proyectoId    String?
  proyecto      Proyecto?           @relation(fields: [proyectoId], references: [id])
  usuarioId     String
  usuario       Usuario             @relation(fields: [usuarioId], references: [id])
  cohesion          Float?
  friccionGrados    Float?
  pesoEspecifico    Float?
  tipoRevestimiento String?
  pais             String?
  zonaSismica      String?
  createdAt      DateTime            @default(now())
  lecturas       LecturaTelemetria[]
}

// ─── LECTURA TELEMETRIA ─────────────────────────────────────────
// Lectura/medición individual de un ActivoTelemetria, con sello de integridad.
model LecturaTelemetria {
  id        String           @id @default(cuid())
  activoId  String
  activo    ActivoTelemetria @relation(fields: [activoId], references: [id])
  magnitud  String
  valor     Float
  unidad    String
  fuente    String
  createdAt DateTime         @default(now())
  usuarioId String
  usuario   Usuario          @relation(fields: [usuarioId], references: [id])
  hash             String?
  firma            String?
  factorSeguridad  Float?
}
