generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIO ─────────────────────────────────────────────────
// Sin cambios — igual al original
model Usuario {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  nombre    String
  empresa   String
  pais      String     @default("Argentina")
  matricula String?    @default("")
  dni       String?    @default("")
  plan        String     @default("demo")
  demoStartAt DateTime?
  planElegido Boolean    @default(false)
  activo           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  resetToken       String?    @unique
  resetTokenExpira DateTime?
  consultasIaUsadas  Int       @default(0)
  consultasIaResetEn DateTime?
  equipoId  String?
  equipo    Equipo?    @relation(fields: [equipoId], references: [id])
  rolEquipo String     @default("miembro")
  calculos  Calculo[]
  proyectos Proyecto[]
}

// ─── EQUIPO ──────────────────────────────────────────────────
// Plan Team: un dueño crea un equipo e invita hasta `limiteMiembros` usuarios.
// Un usuario pertenece a lo sumo a un equipo (equipoId en Usuario).
model Equipo {
  id             String   @id @default(cuid())
  nombre         String
  plan           String   @default("team")
  propietarioId  String
  limiteMiembros Int      @default(3)
  createdAt      DateTime @default(now())
  miembros       Usuario[]
}

// ─── PROYECTO ─────────────────────────────────────────────────
// Agrupa cálculos del mismo activo físico en el tiempo.
// Base del Asset Integrity Management de INGENIUM PRO.
model Proyecto {
  id         String    @id @default(cuid())
  nombre     String
  industria  String    @default("Petróleo / Gas")
  fluido     String?
  presion_bar Float?
  temp_c     Float?
  nps        String?
  material   String?
  norma      String    @default("ASME B31.8")
  H2S_ppm    Float?    @default(0)
  zona_elec  String?
  pais       String    @default("Argentina")
  activo     Boolean   @default(true)
  usuarioId  String
  usuario    Usuario   @relation(fields: [usuarioId], references: [id])
  calculos   Calculo[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ─── CALCULO ──────────────────────────────────────────────────
// Cada cálculo individual con historial y QR verificable.
// Todos los campos nuevos son opcionales — no rompe datos existentes.
model Calculo {
  id           String    @id @default(cuid())
  tipo         String
  moduloId     String?
  submodulo    String?
  activoNombre String?
  parametros   Json
  resultado    Json
  normativa    String?
  hash         String?   @unique
  alerta       Boolean   @default(false)
  alertaMsg    String?
  usuario      String    @default("anonimo")
  usuarioId    String?
  proyectoId   String?
  user         Usuario?  @relation(fields: [usuarioId], references: [id])
  proyecto     Proyecto? @relation(fields: [proyectoId], references: [id])
  createdAt    DateTime  @default(now())
} 