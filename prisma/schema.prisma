generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String
  organization String?
  role String @default("user")
  createdAt DateTime @default(now())
  reports Report[]
}

model Report {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  type String
  parameters String
  results String
  title String?
  createdAt DateTime @default(now())
}